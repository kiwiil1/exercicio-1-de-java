//Desafio 2 = Leia dia, mês e ano de nascimento de uma pessoa e exiba na tela.
 
import java.time.LocalDate;
import java.util.Scanner;

public class nasc {
    public static void main(String[] args) {
        Scanner ler = new Scanner(System.in);

        System.out.print("Digite o dia de seu nascimento: ");
        int dia = ler.nextInt();

        System.out.print("Digite o mês de seu nascimento: ");
        int mes = ler.nextInt();

        System.out.print("Digite o ano de seu nascimento: ");
        int ano = ler.nextInt();

        LocalDate data = LocalDate.of(ano, mes, dia);
        System.out.println("Seu nascimento é na data: " + data);

        ler.close();
    }
}

