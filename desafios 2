import java.util.Scanner;

public class exerc6 {
    public static void main(String[] args) {
        Scanner ler = new Scanner(System.in);

        System.out.print("Digite seu peso:");
        double peso = Double.parseDouble(ler.nextLine());

        System.out.print("Digite sua altura:");
        double alt = Double.parseDouble(ler.nextLine());
        double imc = peso / (alt *alt);

        if (imc < 18.5){
            System.out.print("Classificação: Abaixo do peso. ");
        }else if(imc > 18.5 && imc < 24.9){
            System.out.print("Classificação: Peso ideal. ");
        }else if (imc > 25.0 && imc < 29.9){
            System.out.print("Classificação: Sobrepeso. ");
        }
        else {
            System.out.print("Classificação: Obesidade. ");
        }
        System.out.print("Seu imc é: " + imc);
        ler.close();
    }
}
