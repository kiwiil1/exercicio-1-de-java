  import java.util.Scanner;

public class exerc5 {
    public static void main(String[] args) {
        Scanner ler = new Scanner(System.in);

        System.out.print("Digite o saldo atual: ");
        int saldo = Integer.parseInt(ler.nextLine());

        System.out.print(" 1 - Ver saldo    2 - Sacar dinheiro    3 - Depositar dinheiro    4 - Sair ");
        int menu = Integer.parseInt(ler.nextLine());

        String opcaoMenu;

        switch(menu) {
            case 1:
                System.out.print("Seu saldo é: " + saldo);
                break;
            case 2:
                System.out.print("Qual o valor que deseja sacar? ");
                int valors = Integer.parseInt(ler.nextLine());

                saldo = saldo - valors;
                System.out.print("Saque realizado. Novo Saldo: " + saldo);
                break;
            case 3:
                System.out.print("Qual o valor que deseja depositar? ");
                int valord = Integer.parseInt(ler.nextLine());

                saldo = saldo + valord;
                System.out.print("Deposito realizado. Novo saldo: " + saldo);
                break;
            case 4:
                System.out.print("" + menu);
        }
    }
}

