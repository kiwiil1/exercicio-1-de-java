  import java.util.Scanner;

public class exerc4 {
    public static void main(String[] args){
        Scanner ler = new Scanner(System.in);

        System.out.print("Digite a temperatura em Celsius: ");
        int temp = Integer.parseInt(ler.nextLine());

        System.out.print("Escolha a conversão: 1 - Fahrenheit 2 - Kelvin ");
        int escolha = Integer.parseInt(ler.nextLine());

          if (escolha == 1){
              System.out.print("A temperatura em Fahrenheit é: " + (temp * 9/5 + 32 ));
        }else if (escolha == 2){
              System.out.print("A temperatura em Kelvin é: " + (temp +273));
          }
            ler.close();
    }
}

